let numero1 = parseInt(prompt("Calculadora \n Insira o primeiro número: "))

let numero2 = parseInt(prompt("Insira o segundo número: "))

let equacao = parseInt (prompt("Qual equação? \n 1-soma 2-subtração 3-divisão 4-multiplicação \n"))

if(equacao == 1){
    console.log(numero1 + numero2)
}else if (equacao == 2){
    console.log(numero1 - numero2)
}else if (equacao == 3){
    console.log(numero1 % numero2)
}else if (equacao == 4){
    console.log(numero1 * numero2)
}

